{{- define "join" -}}
  {{- $sep := index . 0 -}}
  {{- $list := index . 1 -}}
  {{- range $i, $v := $list }}{{ if $i }}{{ $sep }}{{ end }}{{ $v }}{{ end -}}
{{- end -}}

{{- define "sequence" -}}
  {{- template "join" (coll.Slice "; wait 0; " .) -}}
{{- end -}}

{{- define "assert_unique" -}}
  {{- assert (eq (len $) (len (uniq $))) -}}
{{- end -}}

{{- define "assert_reorder" -}}
  {{- $lhs := index . 0 -}}
  {{- $rhs := index . 1 -}}
  {{- assert (eq (len $lhs) (len $rhs)) -}}
  {{- range $lhs -}}
    {{- assert (has $rhs .) -}}
  {{- end -}}
  {{- range $rhs -}}
    {{- assert (has $lhs .) -}}
  {{- end -}}
{{- end -}}

{{- $hammer := "slot 1" -}}
{{- $enforcer := `slot 2; wait 0; use QCMachinegun; wait 0; use QCMachinegunDM` -}}
{{- $minigun := `use QCHeavyMachinegun; wait 0; use QCHeavyMachinegunDM` -}}
{{- $dispersion := `slot 3; wait 0; use QCShotgun; wait 0; use QCShotgunDM` -}}
{{- $flak := `use QCSuperShotgun; wait 0; use QCSuperShotgunDM` -}}
{{- $linkgun := `slot 4; wait 0; use QCNailgun; wait 0; use QCNailgunDM` -}}
{{- $pulsegun := `use QCSuperNailgun; wait 0; use QCSuperNailgunDM` -}}
{{- $bio_ripper := "slot 5" -}}
{{- $rocket := "slot 6" -}}
{{- $shock := "slot 7" -}}
{{- $sniper := "slot 8" -}}
{{- $redeemer := "slot 9" -}}
{{- $ability := "slot 0" -}}

{{- $best := coll.Slice
      $dispersion
      $enforcer
      $linkgun
      $pulsegun
      $minigun
      $flak
      $bio_ripper
      $ability
      $shock
      $rocket
      $redeemer
      $sniper
-}}

{{- template "assert_unique" $best -}}

{{- $expl := coll.Slice
      $sniper
      $shock
      $enforcer
      $linkgun
      $dispersion
      $minigun
      $pulsegun
      $flak
      $ability
      $bio_ripper
      $rocket
      $redeemer
-}}

{{- template "assert_reorder" (coll.Slice $best $expl) -}}

{{- $best_str := tmpl.Exec "sequence" $best -}}
{{- $expl_str := tmpl.Exec "sequence" $expl -}}

alias best_into_expl "bind MWheelDown expl_into_best; {{ $best_str }}"
alias expl_into_best "bind MWheelDown best_into_expl; {{ $expl_str }}"

bind Mouse3 "+user1"
bind MWheelUp "bind MWheelDown expl_into_best; {{ $best_str }}"
bind MWheelDown expl_into_best

bind Q "+user1"
bind T "{{ template "sequence" (coll.Slice $dispersion $flak) }}"
bind Y "{{ template "sequence" (coll.Slice $dispersion $flak) }}"
bind F "{{ $sniper }}"
bind G "{{ template "sequence" (coll.Slice $linkgun $pulsegun) }}"
bind Z "{{ $shock }}"
bind X "{{ $rocket }}"
bind C "{{ template "sequence" (coll.Slice $enforcer $minigun) }}"
bind V "{{ $bio_ripper }}"
bind B "{{ $redeemer }}"

name Chancho
fov 120
movebob 0
stillbob 0
switchonpickup 3
cl_noammoswitch false
